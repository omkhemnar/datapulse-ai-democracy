e: 'booth' },\n    { id: 's1', name: 'PM-KISAN', type: 'scheme' },\n    { id: 's2', name: 'Skill India', type: 'scheme' },\n  ],\n  links: [\n    { source: 'v1', target: 'b1' }, { source: 'v2', target: 'b1' },\n    { source: 'v3', target: 'b2' }, { source: 'v1', target: 's1' },\n    { source: 'v2', target: 's2' }, { source: 'b1', target: 's1' },\n  ],\n}\n\nexport default function KnowledgeGraphPage() {\n  const [highlight, setHighlight] = useState(null)\n\n  return (\n    <div>\n      <h1 className=\"text-2xl font-bold text-slate-900 dark:text-white mb-2\">Knowledge Graph</h1>\n      <p className=\"text-slate-500 dark:text-slate-400 mb-6\">\n        Interactive graph: Voters, Booths, Government Schemes — scroll to zoom, drag to pan\n      </p>\n\n      <div className=\"flex gap-4 mb-4 text-sm text-slate-500\">\n        <span className=\"flex items-center gap-2\"><span className=\"w-3 h-3 rounded-full bg-[#0ea5e9]\" /> Voters</span>\n        <span className=\"flex items-center gap-2\"><span className=\"w-3 h-3 rounded-full bg-[#14b8a6]\" /> Booths</span>\n        <span className=\"flex items-center gap-2\"><span className=\"w-3 h-3 rounded-full bg-[#f97316]\" /> Schemes</span>\n      </div>\n\n      <Card>\n        <CardHeader title=\"Graph Visualization\" subtitle=\"Click nodes to highlight relationships\" />\n        <CardContent>\n          <div className=\"h-[500px] rounded-lg bg-slate-100 dark:bg-slate-800 overflow-hidden\">\n            {ForceGraph2D ? (\n              <ForceGraph2D\n                graphData={sampleGraph}\n                nodeLabel=\"name\"\n                nodeColor={(n) =>\n                  n.type === 'voter' ? '#0ea5e9' : n.type === 'booth' ? '#14b8a6' : '#f97316'\n                }\n                linkColor={() => '#94a3b8'}\n                onNodeClick={(n) => setHighlight(n?.name)}\n              />\n            ) : (\n              <div className=\"text-center\">\n                <Network className=\"w-16 h-16 text-slate-400 mx-auto mb-4\" />\n                <p className=\"text-slate-500\">Graph visualization</p>\n                <p className=\"text-sm text-slate-400 mt-1\">Run: npm install react-force-graph-2d</p>\n              </div>\n            )}\n          </div>\n        </CardContent>\n      </Card>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\project1\\DataPulse_India_Innovates_2026-main\\DataPulse_India_Innovates_2026-main\\datapulse-ai-democracy\\frontend\\src\\pages\\LandingPage.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\project1\\DataPulse_India_Innovates_2026-main\\DataPulse_India_Innovates_2026-main\\datapulse-ai-democracy\\frontend\\src\\pages\\LoginPage.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\project1\\DataPulse_India_Innovates_2026-main\\DataPulse_India_Innovates_2026-main\\datapulse-ai-democracy\\frontend\\src\\pages\\VoterSegmentationPage.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\project1\\DataPulse_India_Innovates_2026-main\\DataPulse_India_Innovates_2026-main\\datapulse-ai-democracy\\frontend\\tailwind.config.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\project1\\DataPulse_India_Innovates_2026-main\\DataPulse_India_Innovates_2026-main\\datapulse-ai-democracy\\frontend\\vite.config.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]}]